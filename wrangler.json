{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "airhouse-festival-back",
  "main": "./src/worker/index.ts",
  "compatibility_date": "2026-02-15",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "version_metadata": { "binding": "CF_VERSION_METADATA" },
  "upload_source_maps": true,
  "vars": {
    "BETTER_AUTH_URL": "https://api.airhouse.name",
    "AUTH_TRUSTED_ORIGINS": "https://airhouse.name,https://www.airhouse.name,https://the-airhouse.com,https://www.the-airhouse.com,airhouseapp://",
    "AUTH_EMAIL_CALLBACK_URL": "https://www.the-airhouse.com/",
    "EMAIL_VERIFICATION_ENABLED": "1",
    "REQUIRE_EMAIL_VERIFICATION": "1",
    "EMAIL_FROM": "The Air House <noreply@airhouse.name>",
    "CONTENT_EXPORT_TOKEN": "AZDX2ON$74cE0ByAIny9z^aU^VET$Rko"
  },
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "763afcdd7ae0400ab94d737288ff3c3f",
      "localConnectionString": "postgresql://user:password@127.0.0.1:5432/database?sslmode=require&channel_binding=require"
    }
  ],
  "r2_buckets": [
    {
      "binding": "CONTENT_EXPORT_BUCKET",
      "bucket_name": "airhouse"
    }
  ]
}
