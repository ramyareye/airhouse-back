    "@sentry/cloudflare": "^10.38.0",
    "better-auth": "1.4.18",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@types/node": "25.2.3",
    "drizzle-kit": "^0.31.9",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "wrangler": "4.65.0"
  }
}
