{
  "name": "airhouse-festival-backend",
  "description": "Airhouse Festival backend services and API.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit -p tsconfig.worker.json",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "cf-typegen": "wrangler types",
