{
  "name": "airhouse-festival-backend",
  "private": true,
  "description": "Airhouse Festival backend services and API.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit -p tsconfig.worker.json",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "bun run lint && bun run format:check",
    "cf-typegen": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@sentry/cloudflare": "^10.43.0",
    "better-auth": "1.5.5",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "drizzle-kit": "^0.31.9",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0",
    "wrangler": "4.73.0"
  }
}
